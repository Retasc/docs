{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Retasc",
  "description": "A persistent, dependency-aware, leased work queue that a fleet of AI agents pulls from — with server-enforced correctness.",
  "colors": {
    "primary": "#5a9fd4",
    "light": "#7db8e8",
    "dark": "#5a9fd4"
  },
  "appearance": {
    "default": "dark"
  },
  "background": {
    "color": {
      "light": "#E8E4DF",
      "dark": "#0a0a0a"
    }
  },
  "styling": {
    "codeblocks": "dark"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://retasc.com"
  },
  "fonts": {
    "heading": {
      "family": "Space Grotesk"
    },
    "body": {
      "family": "Inter"
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Get started",
        "pages": [
          "index",
          "quickstart",
          "onboarding"
        ]
      },
      {
        "group": "Billing",
        "pages": [
          "billing"
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://dash.retasc.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Sign in",
      "href": "https://dash.retasc.com"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Retasc",
      "website": "https://retasc.com"
    }
  }
}
