{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Retasc",
  "description": "A persistent, dependency-aware, leased work queue that a fleet of AI agents pulls from, with server-enforced correctness.",
  "colors": {
    "primary": "#16a34a",
    "light": "#4ade80",
    "dark": "#16a34a"
  },
  "appearance": {
    "default": "dark"
  },
  "background": {
    "color": {
      "light": "#E8E4DF",
      "dark": "#0a0a0a"
    }
  },
  "styling": {
    "codeblocks": "dark"
  },
  "contextual": {
    "display": "header",
    "options": [
      "copy",
      "view",
      "claude",
      "chatgpt",
      "perplexity",
      "cursor",
      "vscode"
    ]
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://retasc.com"
  },
  "fonts": {
    "heading": {
      "family": "Space Grotesk"
    },
    "body": {
      "family": "Inter"
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Get started",
        "pages": [
          "index",
          "quickstart",
          "agent-onboarding",
          "onboarding"
        ]
      },
      {
        "group": "Workflow",
        "pages": [
          "review",
          "notifications"
        ]
      },
      {
        "group": "Billing",
        "pages": [
          "billing"
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Home",
        "href": "https://retasc.com"
      },
      {
        "label": "Docs",
        "href": "https://docs.retasc.com"
      },
      {
        "label": "GitHub",
        "href": "https://github.com/Retasc"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Sign in",
      "href": "https://dash.retasc.com"
    }
  },
  "footer": {
    "links": [
      {
        "header": "Retasc",
        "items": [
          {
            "label": "Home",
            "href": "https://retasc.com"
          },
          {
            "label": "Docs",
            "href": "https://docs.retasc.com"
          },
          {
            "label": "Dashboard",
            "href": "https://dash.retasc.com"
          }
        ]
      },
      {
        "header": "Resources",
        "items": [
          {
            "label": "GitHub",
            "href": "https://github.com/Retasc"
          }
        ]
      }
    ],
    "socials": {
      "github": "https://github.com/Retasc",
      "website": "https://retasc.com"
    }
  }
}
